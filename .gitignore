.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# --- Claude Code local session settings ---
.claude/settings.local.json

# --- Local user store (passwords are hashed but still don't commit) ---
data/users.json
data/users.json.tmp
data/active_session.json
data/active_session.json.tmp

# --- User memory (personal facts) and local caches — never commit ---
data/memory.json
data/memory.json.tmp
data/cache/

# --- Chat history and per-session UI state — never commit ---
data/chats/
data/current_chat.json
data/pending_attachments.json
data/selected_model.json


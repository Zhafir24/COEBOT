# --- Project-specific: data & artifacts ---
# User documents — never commit
data/documents/*
!data/documents/.gitkeep

# Vector DB — local, regenerable
data/chroma_db/*
!data/chroma_db/.gitkeep

# Downloaded models — the models/ folder is ignored but its README
# stays tracked so newcomers know what to put there.
models/*
!models/README.md
*.bin
*.gguf
*.safetensors
*.onnx

# Logs
logs/
*.log


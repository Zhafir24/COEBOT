# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# --- Local LLM (llama-cpp-python, in-process) ---
# Drop a GGUF model file into ./models/ (see models/README.md for details).
# If MODEL_FILENAME is unset, COEBOT auto-detects the first .gguf found.
# Example: MODEL_FILENAME=qwen2.5-7b-instruct-q4_k_m.gguf
MODEL_FILENAME=
# Context window size in tokens (must not exceed the model's max).
MODEL_N_CTX=8192
# CPU threads for inference. 0 = auto-detect based on core count.
MODEL_N_THREADS=0
# Max tokens the model may generate per response (ceiling, not target —
# short answers still stop naturally). Raise if long answers truncate.
MODEL_MAX_TOKENS=3072

# --- Persistent KV cache (speeds up repeat document questions) ---
# Saves the processed-prompt state to disk so re-asking about the same
# documents skips most of the "reading" phase, even across restarts.
KV_CACHE_ENABLED=true
KV_CACHE_DIR=./data/cache/kv
KV_CACHE_GB=8

# --- Embedding model (HuggingFace identifier) ---
# Downloaded once on first run, cached locally.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=documents

# --- RAG tuning ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=4

# --- Logging ---
LOG_LEVEL=INFO
